{
  "name": "tutien-bot",
  "version": "1.0.0",
  "description": "Discord RPG xianxia bot — multi-shard, i18n, TypeScript",
  "type": "module",
  "main": "dist/bot.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "tsx --watch src/shard.ts",
    "start": "node dist/bot.js",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "migrate": "drizzle-kit migrate",
    "prepare": "husky",
    "check-i18n": "tsx scripts/check-i18n.ts"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --max-warnings=0"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/genZVN2021/tutien-bot.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/genZVN2021/tutien-bot/issues"
  },
  "homepage": "https://github.com/genZVN2021/tutien-bot#readme",
  "dependencies": {
    "@discordjs/rest": "2.6.1",
    "discord.js": "14.26.2",
    "dotenv": "17.4.1",
    "drizzle-orm": "0.45.2",
    "fastify": "5.8.4",
    "i18next": "26.0.4",
    "i18next-fs-backend": "2.6.3",
    "ioredis": "5.10.1",
    "pg": "8.20.0",
    "pg-boss": "12.15.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "22.19.17",
    "@types/pg": "8.20.0",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-plugin-i18next": "6.1.3",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "pm2": "6.0.14",
    "tsc-alias": "1.8.16",
    "tsx": "4.21.0",
    "typescript": "5.8.3",
    "typescript-eslint": "8.58.1",
    "vitest": "3.1.2"
  }
}
