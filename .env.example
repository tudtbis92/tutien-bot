# Discord
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id

# Database — runtime (via PgBouncer, port 6432)
DATABASE_URL=postgresql://tutien:password@localhost:6432/tutien

# Database — migrations only (direct PostgreSQL, port 5432)
DATABASE_URL_DIRECT=postgresql://tutien:password@localhost:5432/tutien

# Redis
REDIS_URL=redis://localhost:6379

# App
NODE_ENV=development
PORT=3000

# API-Football API key(s) — comma-separated for key rotation (D-17)
# ⚠️ API-Football ToS forbids multiple free accounts. Use single paid key or member-invite keys from same account.
API_FOOTBALL_KEYS=your_api_key_here

